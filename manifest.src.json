{
  "manifest_version": 3,
  "name": "SignalX",
  "version": "1.0.1",
  "description": "Multi-source news aggregation with BYOK AI summaries and source comparison.",
  "minimum_chrome_version": "114",
  "permissions": [
    "sidePanel",
    "storage",
    "tabs"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'none'; frame-ancestors 'none'"
  },
  "host_permissions": [
    "https://feeds.bbci.co.uk/*",
    "https://rss.cnn.com/*",
    "https://news.google.com/*",
    "https://timesofindia.indiatimes.com/*",
    "https://www.hindustantimes.com/*",
    "https://www.thehindu.com/*",
    "https://indianexpress.com/*",
    "https://feeds.feedburner.com/*",
    "https://rss.nytimes.com/*",
    "https://feeds.a.dj.com/*",
    "https://www.theguardian.com/*",
    "https://www.abc.net.au/*",
    "https://www.smh.com.au/*",
    "https://www.channelnewsasia.com/*",
    "https://www.straitstimes.com/*",
    "https://www.aljazeera.com/*",
    "https://rss.dw.com/*",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://openrouter.ai/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/panel/panel.html"
  },
  "action": {
    "default_title": "Open SignalX",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}